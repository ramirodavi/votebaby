# Configurações do Banco de Dados PostgreSQL
PG_USER=
PG_HOST=
PG_DATABASE=
PG_PASSWORD=
PG_PORT=

# Ambiente de execução (production | development | test)
# - production: habilita SSL na conexão com o banco de dados (necessário no Render/Neon)
# - development ou qualquer outro valor: desabilita SSL (para uso local sem certificado)
NODE_ENV=production

# URL de origem do frontend autorizada pelo CORS (apenas scheme + hostname, sem path)
# Exemplo GitHub Pages: https://fulanodetal.github.io
# Exemplo Render:       https://seu-frontend.onrender.com
FRONTEND_URL=https://seu-frontend.onrender.com

# URL pública do backend, devolvida ao frontend via rota /config para montar todas as chamadas de API
# - development: pode deixar vazio (fallback: http://localhost:3000)
# - production:  OBRIGATÓRIO preencher com a URL do Render, senão o frontend recebe localhost e quebra
API_URL=

# Porta onde o servidor escutará
# - development: pode deixar vazio (fallback: 3000)
# - production:  deixar vazio — o Render injeta automaticamente em tempo de execução
PORT=

# Nomes dos bebês
BABY_BOY_NAME=Francisco
BABY_GIRL_NAME=Cecília

# Resultado do chá revelação (opções: "boy", "girl", "pending")
REVEAL_RESULT=girl

# Texto adicional para a revelação
REVEAL_TEXT=Cecília vem ao mundo

# Cores para o sexo masculino
BOY_COLOR=rgb(58, 177, 98)
BG_BOY_COLOR=rgb(172, 241, 197)

# Cores para o sexo feminino
GIRL_COLOR=rgb(219, 130, 207)
BG_GIRL_COLOR=rgb(231, 179, 223)

# Cores dos balões
BALLOON_BOY_COLOR=rgb(58, 177, 98)
BALLOON_GIRL_COLOR=rgb(219, 130, 207)

# Cores do fundo da div de revelação
REVEAL_BG_BOY_COLOR=rgb(172, 241, 197)
REVEAL_BG_GIRL_COLOR=rgb(231, 179, 223)

# Ativar/desativar o scroll automático (opções: "true", "false")
ENABLE_AUTO_SCROLL=true
